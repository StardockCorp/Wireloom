# Colonial Charter screen from Galactic Civilizations IV.
# Rewritten for v0.2 using real tabs, sections, kv rows, slots, and badges.
# Compare against 11-colonial-charter.wireloom history in git for the
# v0.1 workaround version that lived in panels of text+row children.

window "CIVILIZATION":
  header:
    text "Colonial Charter" size=large

  tabs:
    tab "Government" active
    tab "Leaders"
    tab "Ministers"
    tab "Diplomats"
    tab "Governors"
    tab "Commanders"
    tab "Institutions"
    tab "Parties"

  row:

    # Left column: fixed 340px
    col 340:

      section "Economy":
        kv "Tax Rate" "30%"
        slider range=0-100 value=30
        kv "Approval" "Content (72%)"

      section "Gross Income":
        kv "Colony Income" "+612"
        kv "Trade Routes" "+145"
        kv "Treaty Income" "+62"
        kv "Tax Rate (30%)" "+28"
        divider
        kv "Total Income" "+847 bc" bold

      section "Expenses":
        kv "Ship Maintenance" "-245"
        kv "Colony Maintenance" "-180"
        kv "Starbase Maintenance" "-95"
        kv "Treaty Maintenance" "-52"
        kv "Policy Maintenance" "-40"
        divider
        kv "Total Expenses" "-612 bc" bold

      section "Net":
        kv "Net Income" "+235 bc" bold size=large
        kv "Treasury" "4,250 bc"

      section "Civilization":
        kv "Government" "Colonial Charter"
        kv "Colonies" "12"
        kv "Citizens" "24.5B"

    # Center column: fill remaining space
    col:
      section "Enacted Policies" badge="4 / 7 slots filled":
        list:
          slot "Colonial Defense Pact":
            text "+15% Planetary Defense"
            text "All colonies gain defensive bonuses" muted
          slot "Free Market Initiative":
            text "+10% Income, -5% Approval"
            text "Deregulated trade increases revenue" muted
          slot "Research Subsidies" active:
            text "+20% Research Output"
            text "Government funded research programs" muted
            row align=right:
              button "Revoke"
          slot "Cultural Exchange":
            text "+10% Influence, +5% Tourism"
            text "Interstellar cultural programs" muted
          slot "Empty Policy Slot":
            text "Choose a policy from the available list" muted italic
          slot "Empty Policy Slot":
            text "Choose a policy from the available list" muted italic
          slot "Empty Policy Slot":
            text "Choose a policy from the available list" muted italic

    # Right column: fixed 360px
    col 360:
      section "Available Policies":
        list:
          slot "Frontier Expansion":
            text "+20% Colony Speed, +10% Growth"
            text "Prioritize outward expansion" muted
            row align=right:
              text "2 Admin" muted size=small
              button "Enact" primary
          slot "Militia Training":
            text "+15% Planetary Defense, +10% Military"
            text "Arm the colonists" muted
            row align=right:
              text "3 Admin" muted size=small
              button "Enact" primary
          slot "Trade Agreements":
            text "+20% Trade Route Income"
            text "Establish favorable trade terms" muted
            row align=right:
              text "2 Admin" muted size=small
              button "Enact" primary
          slot "Infrastructure Investment":
            text "+15% Manufacturing, +10% Growth"
            text "Build foundational industry" muted
            row align=right:
              text "3 Admin" muted size=small
              button "Enact" primary
          slot "Diplomatic Corps":
            text "+15% Influence, +10% Diplomacy"
            text "Invest in foreign relations" muted
            row align=right:
              text "2 Admin" muted size=small
              button "Enact" primary
          slot "Pioneer Spirit":
            text "+15% Approval, +10% Morale"
            text "Foster community and purpose" muted

  footer:
    row:
      button "Change Government"
      row align=right:
        button "Done" primary
